# Pin the repository toolchain used by Just recipes.
GOTOOLCHAIN=go1.26.5

HOST=0.0.0.0
PORT=8080
APP_ENVIRONMENT=development
LOG_LEVEL=info

# offline: public routes run locally; protected routes return 503.
# emulator: requires both emulator hosts and a demo-* project.
# live: requires a non-demo project and Application Default Credentials.
FIREBASE_MODE=offline
FIREBASE_PROJECT_ID=demo-test-project

# Required outside development. Comma-separate multiple origins.
# CORS_ALLOWED_ORIGINS=https://example.com

# Uncomment together with FIREBASE_MODE=emulator.
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:7110
# FIRESTORE_EMULATOR_HOST=127.0.0.1:7130

# Optional: raises GitHub API rate limits. Never log this value.
# GITHUB_TOKEN=
